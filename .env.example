# Django - development defaults
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_WS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_TRUST_X_FORWARDED_PROTO=0

# JWT
DJANGO_ACCESS_TOKEN_MINUTES=15
DJANGO_REFRESH_TOKEN_DAYS=7

# Refresh cookie - local dev
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth/
AUTH_REFRESH_COOKIE_SAMESITE=Lax
AUTH_REFRESH_COOKIE_SECURE=0

# Database
POSTGRES_DB=turnieje
POSTGRES_USER=turnieje
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
FRONTEND_RESET_URL=http://localhost:5173/reset-password

# Email - development sandbox
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASSWORD=your_mailtrap_password

# PgAdmin - local only
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=change-me

# Production hints:
# DJANGO_DEBUG=0
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_TRUST_X_FORWARDED_PROTO=1
# VITE_API_BASE_URL=https://api.twoja-domena.pl
# VITE_WS_BASE_URL=wss://api.twoja-domena.pl
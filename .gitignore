# Pliki środowiskowe (root)
.env
.env.*
!.env.example
.envrc

# Root npm (brak package.json w roocie - zabezpieczenie)
node_modules/
/package-lock.json

# Python / Django
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
*.sqlite3
*.db

# Cache i narzędzia testowe
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
htmlcov/
coverage.xml
pip-log.txt
.python-version

# Jupyter (gdyby pojawiły się notatniki badawcze/testowe)
.ipynb_checkpoints/

# Django - lokalne overridy (gdyby powstały)
backend/local_settings.py

# Python - środowiska wirtualne
venv/
.venv/

# Backend - artefakty lokalne (zachowanie struktury katalogów przez .gitkeep)
backend/media/*
!backend/media/.gitkeep
backend/staticfiles/*
!backend/staticfiles/.gitkeep

# Frontend - zależności i buildy
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/

# Frontend - środowisko i cache
frontend/.env
frontend/.env.*
!frontend/.env.example
frontend/.vite/
frontend/.eslintcache
*.tsbuildinfo

# Alternatywne menadżery pakietów (zabezpieczenie)
.pnpm-store/

# Logi JS / npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Logi globalne
*.log
logs/

# Docker - lokalne overridy
docker-compose.override.yml
docker-compose.*.local.yml

# Certyfikaty i klucze (profilaktycznie)
*.pem
*.key
*.crt
*.p12
*.pfx

# Kopie zapasowe i pliki tymczasowe
*.bak
*.tmp
*.orig
*~
.history/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Visual Studio (opcjonalnie - na wypadek pracy na Windows)
*.suo
*.ntvs*
*.njsproj
*.sln

# System - macOS
.DS_Store

# System - Windows
Thumbs.db
ehthumbs.db
desktop.ini